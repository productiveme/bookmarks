---
import Layout from '../layouts/Layout.astro';
import { generateBookmarklet } from '../utils/bookmarklet.js';
import '../styles/global.css';

const appUrl = import.meta.env.PUBLIC_APP_URL || 'http://localhost:4321';
const bookmarkletCode = generateBookmarklet(appUrl);
---

<Layout title="Bookmarks Bar - Setup">
  <main class="min-h-screen bg-[var(--color-bg-secondary)] flex items-center justify-center p-8">
    <div class="max-w-3xl mx-auto text-center">
      <div class="flex items-center justify-center gap-4 mb-4">
        <h1 class="text-4xl font-bold text-[var(--color-text-primary)]">
          Bookmarks Bar
        </h1>
        <a 
          href="https://github.com/productiveme/bookmarks" 
          target="_blank"
          class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
          title="View on GitHub"
        >
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
      <p class="text-lg text-[var(--color-text-secondary)] mb-8">
        A minimal bookmark manager that lives in your browser, powered by GitHub Gist
      </p>
      
      <div class="bg-[var(--color-bg-primary)] rounded-lg shadow-xl p-8 mb-8 border border-[var(--color-border)] text-left">
        <h2 class="text-2xl font-semibold mb-4 text-[var(--color-text-primary)]">
          Getting Started
        </h2>
        
        <ol class="space-y-4 text-[var(--color-text-primary)]">
          <li class="flex gap-3">
            <span class="font-bold text-[var(--color-accent)]">1.</span>
            <div>
              <strong>Create a GitHub Personal Access Token</strong>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">
                Go to <a href="https://github.com/settings/tokens" target="_blank" class="text-[var(--color-accent)] hover:underline">github.com/settings/tokens</a> and create a token with <code class="bg-[var(--color-bg-secondary)] px-1 py-0.5 rounded">gist</code> scope
              </p>
            </div>
          </li>
          
          <li class="flex gap-3">
            <span class="font-bold text-[var(--color-accent)]">2.</span>
            <div>
              <strong>Configure your bookmarks</strong>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">
                <a href="/setup" target="_blank" class="text-[var(--color-accent)] hover:underline">Click here to set up</a> your GitHub token and create a new Gist
              </p>
            </div>
          </li>
          
          <li class="flex gap-3">
            <span class="font-bold text-[var(--color-accent)]">3.</span>
            <div>
              <strong>Install the Bookmarklet</strong>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">
                Drag this button to your bookmarks bar:
              </p>
              <div class="flex items-center gap-2 mt-2">
                <a
                  href={bookmarkletCode}
                  class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-accent)] text-white rounded hover:bg-[var(--color-accent-hover)] transition-colors no-underline font-medium"
                  onclick="alert('Drag this button to your bookmarks bar!'); return false;"
                >
                  <span>⚐ Bookmarks</span>
                </a>
                <button
                  id="copy-bookmarklet"
                  class="px-3 py-2 bg-[var(--color-bg-secondary)] text-[var(--color-text-primary)] rounded hover:bg-[var(--color-border)] transition-colors border border-[var(--color-border)]"
                  title="Copy bookmarklet code"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
            </div>
          </li>
          
          <li class="flex gap-3">
            <span class="font-bold text-[var(--color-accent)]">4.</span>
            <div class="flex-1">
              <strong>Use it anywhere</strong>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">
                Click the bookmarklet on any webpage to show your bookmarks bar
              </p>
              <a 
                href="/bookmarks" 
                class="mt-2 inline-block w-full px-4 py-2 bg-[var(--color-bg-secondary)] text-[var(--color-text-primary)] rounded hover:bg-[var(--color-border)] transition-colors border border-[var(--color-border)] text-center no-underline"
              >
                Open Bookmarks
              </a>
            </div>
          </li>
        </ol>
      </div>
      
      <div class="bg-[var(--color-bg-primary)] rounded-lg shadow-xl p-6 border border-[var(--color-border)] text-left">
        <h3 class="text-xl font-semibold mb-3 text-[var(--color-text-primary)]">
          Features
        </h3>
        <ul class="space-y-2 text-[var(--color-text-secondary)]">
          <li>✓ Organize bookmarks in folders and subfolders</li>
          <li>✓ Quick access from any webpage</li>
          <li>✓ Add current page with one click</li>
          <li>✓ Synced via GitHub Gist</li>
          <li>✓ Light/Dark theme support</li>
          <li>✓ Privacy-focused (your data stays in your Gist)</li>
        </ul>
      </div>
    </div>
  </main>
  
  <script define:vars={{ bookmarkletCode }}>
    // Copy bookmarklet code to clipboard
    document.getElementById('copy-bookmarklet')?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(bookmarkletCode);
        const button = document.getElementById('copy-bookmarklet');
        const originalHTML = button.innerHTML;
        
        // Show success feedback
        button.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
        button.classList.add('bg-green-500', 'text-white');
        
        setTimeout(() => {
          button.innerHTML = originalHTML;
          button.classList.remove('bg-green-500', 'text-white');
        }, 2000);
      } catch (err) {
        alert('Failed to copy: ' + err.message);
      }
    });
  </script>
</Layout>
