---
const appUrl = import.meta.env.PUBLIC_APP_URL || 'http://localhost:4321';
---

<html>
  <head>
    <title>Debug - Bookmarks Bar</title>
    <style>
      body {
        font-family: monospace;
        padding: 20px;
        background: #1e1e1e;
        color: #d4d4d4;
      }
      .info {
        background: #252526;
        padding: 15px;
        border-radius: 5px;
        margin: 10px 0;
      }
      .label {
        color: #569cd6;
        font-weight: bold;
      }
      .value {
        color: #ce9178;
      }
    </style>
  </head>
  <body>
    <h1>Bookmarks Bar - Debug Info</h1>
    
    <div class="info">
      <div class="label">PUBLIC_APP_URL:</div>
      <div class="value">{appUrl}</div>
    </div>
    
    <div class="info">
      <div class="label">Node Version:</div>
      <div class="value">{process.version}</div>
    </div>
    
    <div class="info">
      <div class="label">Environment:</div>
      <div class="value">{import.meta.env.MODE}</div>
    </div>
    
    <p style="margin-top: 30px;">
      <a href="/" style="color: #4fc3f7;">← Back to Home</a>
    </p>
  </body>
</html>
